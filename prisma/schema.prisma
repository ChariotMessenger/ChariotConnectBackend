generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  RIDER
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OrderStatus {
  WAITING_FOR_APPROVAL
  AWAITING_PAYMENT
  PAID                         
  VENDOR_PACKING               
  AWAITING_PICK_UP             
  RIDER_ACCEPTED              
  RIDER_EN_ROUTE_TO_VENDOR
  RIDER_EN_ROUTE_TO_CUSTOMER
  DELIVERED
  CANCELLED
  REJECTED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum OnlineStatus {
  ONLINE
  OFFLINE
}

type Point {
  latitude     Float?
  longitude    Float?
  locationName String?
}

model Customer {
  id                     String            @id @default(auto()) @map("_id") @db.ObjectId
  firstName              String
  lastName               String
  email                  String            @unique
  phone                  String
  birthday               DateTime
  gender                 String
  country                String
  currency               String            @default("NGN")
  isEmailVerified        Boolean           @default(false)
  profilePhotoUrl        String?
  password               String
  currentLocation        Point?
  receiveMarketingEmails Boolean           @default(false)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  otpVerifications       OTPVerification[]
  favorites              FavoriteVendor[]
  customerReviews        Review[]          @relation("CustomerReviews")
  messages               Message[]         @relation("CustomerMessages")
  messageRooms           MessageRoom[]     @relation("CustomerRooms")
  orders                 Order[]           @relation("CustomerOrders")

  @@index([country])
}

model Vendor {
  id                     String             @id @default(auto()) @map("_id") @db.ObjectId
  firstName              String
  lastName               String
  email                  String             @unique
  phone                  String
  country                String
  currency               String             @default("NGN")
  businessType           String
  businessName           String
  businessAddress        Point?
  isEmailVerified        Boolean            @default(false)
  isOwner                Boolean
  businessOwnerName      String?
  isBusinessRegistered   Boolean
  profilePhotoUrl        String?
  currentLocation        Point?
  password               String
  receiveMarketingEmails Boolean            @default(false)
  verificationStatus     VerificationStatus @default(PENDING)
  verified               Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  otpVerifications       OTPVerification[]
  favoritedBy            FavoriteVendor[]
  catalogItems           CatalogItem[]
  vendorReviews          Review[]           @relation("VendorReviews")
  orders                 Order[]            @relation("VendorOrders")
  messages               Message[]          @relation("VendorMessages")
  messageRooms           MessageRoom[]      @relation("VendorRooms")

  @@index([country])
  @@index([businessType])
}

model Rider {
  id                    String             @id @default(auto()) @map("_id") @db.ObjectId
  firstName             String
  lastName              String
  email                 String             @unique
  phone                 String
  birthday              DateTime
  gender                String
  country               String
  currency              String             @default("NGN")
  isEmailVerified       Boolean            @default(false)
  state                 String
  areaOfWork            String
  drivingLicenseUrl     String
  ninNumber             String
  currentLocation       Point?
  idCardUrl             String
  bikePlateNumber       String
  password              String
  profilePhotoUrl       String?
  guarantorName         String
  guarantorRelationship String
  guarantorPhone        String
  guarantorNin          String
  guarantorIdCardUrl    String
  bankName              String
  accountNumber         String
  accountName           String
  verifyIdentityUrl     String
  onlineStatus          OnlineStatus       @default(OFFLINE)
  verificationStatus    VerificationStatus @default(PENDING)
  verified              Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  otpVerifications      OTPVerification[]
  deliveries            Order[]            @relation("RiderOrders")

  @@index([country])
  @@index([state])
  @@index([onlineStatus])
}

model Order {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  vendorId         String      @db.ObjectId
  customerId       String      @db.ObjectId
  riderId          String?     @db.ObjectId
  items            Json
  totalAmount      Float
  currency         String
  status           OrderStatus @default(WAITING_FOR_APPROVAL)
  notes            String?
  deliveryLocation Point?
  pickupLocation   Point?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  pickupAt         DateTime?     
  deliveredAt      DateTime?
  transactions Transaction[]
  vendor       Vendor        @relation("VendorOrders", fields: [vendorId], references: [id], onDelete: Cascade)
  customer     Customer      @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  rider        Rider?        @relation("RiderOrders", fields: [riderId], references: [id])

  @@index([vendorId])
  @@index([customerId])
  @@index([riderId])
  @@index([status])
}

model OTPVerification {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  code         String
  email        String
  userType     UserRole
  userId       String?   @db.ObjectId
  expiresAt    DateTime
  verified     Boolean   @default(false)
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())
  customer     Customer? @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor       Vendor?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rider        Rider?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([userId])
}

model CatalogItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  vendorId    String   @db.ObjectId
  name        String
  description String?
  price       Float
  imageUrl    String?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  vendorId   String   @db.ObjectId
  customerId String   @db.ObjectId
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vendor     Vendor   @relation("VendorReviews", fields: [vendorId], references: [id], onDelete: Cascade)
  customer   Customer @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([vendorId, customerId])
  @@index([vendorId])
  @@index([customerId])
}

model FavoriteVendor {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  vendorId   String   @db.ObjectId
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([customerId, vendorId])
  @@index([customerId])
  @@index([vendorId])
}

model MessageRoom {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  customerId String    @db.ObjectId
  vendorId   String    @db.ObjectId
  messages   Message[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer  @relation("CustomerRooms", fields: [customerId], references: [id], onDelete: Cascade)
  vendor     Vendor    @relation("VendorRooms", fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([customerId, vendorId])
  @@index([customerId])
  @@index([vendorId])
}

model Message {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  roomId     String        @db.ObjectId
  senderId   String        @db.ObjectId
  senderType UserRole
  content    String
  status     MessageStatus @default(SENT)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  room       MessageRoom   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  customer   Customer?     @relation("CustomerMessages", fields: [senderId], references: [id], onDelete: Cascade)
  vendor     Vendor?       @relation("VendorMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([senderId])
  @@index([status])
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

model Admin {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String      @unique
  password  String
  roleId    String      @db.ObjectId
  status    AdminStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  role      Role        @relation(fields: [roleId], references: [id])

  @@index([status])
}

model Role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String   @unique
  description String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admins      Admin[]
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Transaction {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId        String        @db.ObjectId
  reference      String        @unique
  amount         Float
  currency       String
  status         PaymentStatus @default(PENDING)
  provider       String        @default("PAYSTACK")
  paymentDetails String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}